class ConfigManager:
    """Verwaltet die Konfiguration und den API-Key."""
    def __init__(self):
        self.token = self._load_token()

    def _load_token(self):
        # 1. Priorität: Umgebungsvariable
        env_token = os.environ.get("GALERT_API_KEY")
        if env_token:
            return env_token
        
        # 2. Priorität: Konfigurationsdatei
        if CONFIG_FILE.exists():
            config = configparser.ConfigParser()
            try:
                config.read(CONFIG_FILE)
                if "API" in config and "token" in config["API"]:
                    return config["API"]["token"]
            except Exception:
                pass
        
        # 3. Priorität: Hardcoded Default
        return DEFAULT_TOKEN

class FreesoundAPI:
    """Kommunikation mit der Freesound.org APIv2."""
    BASE_URL = "https://freesound.org/apiv2"

    def __init__(self, token):
        self.token = token

    def search(self, query, limit=5):
        url = f"{self.BASE_URL}/search/text/"
        params = {
            "query": query,
            "token": self.token,
            "filter": 'license:"Creative Commons 0" OR license:"Attribution"',
            "fields": "id,name,license,previews",
            "page_size": limit
        }
        try:
            response = requests.get(url, params=params, timeout=10)
            response.raise_for_status()
            return response.json().get("results", [])
        except requests.exceptions.RequestException as e:
            print(f"Fehler bei der API-Anfrage: {e}")
            return []

    def download_preview(self, preview_url, target_path):
        try:
            response = requests.get(preview_url, stream=True, timeout=15)
            response.raise_for_status()
            with open(target_path, "wb") as f:
                for chunk in response.iter_content(chunk_size=8192):
                    f.write(chunk)
            
            # DOWNLOAD-SCHUTZ: Existenz und Größe prüfen
            if target_path.exists() and target_path.stat().st_size > 0:
                return True
            else:
                print("[-] Fehler: Heruntergeladene Datei ist leer oder korrupt.")
                return False
        except requests.exceptions.RequestException as e:
            print(f"Fehler beim Download: {e}")
            return False
        except IOError as e:
            print(f"[-] Fehler beim Schreiben der Datei: {e}")
            return False

class AudioPlayer:
    """Spielt Audio-Dateien mit verschiedenen Fallbacks ab."""
    @staticmethod
    def play(file_path):
        # DOWNLOAD-SCHUTZ: Vor Wiedergabe prüfen
        if not file_path.exists() or file_path.stat().st_size == 0:
            print("[-] Fehler: Audio-Datei existiert nicht oder ist leer.")
            return False

        # Fallback-Kette: paplay -> ogg123 -> aplay
        players = [
            ["paplay", str(file_path)],
            ["ogg123", "-q", str(file_path)],
            ["aplay", str(file_path)]
        ]
        
        for cmd in players:
            if shutil.which(cmd[0]):
                try:
                    subprocess.run(cmd, check=True, stderr=subprocess.DEVNULL)
                    return True
                except subprocess.CalledProcessError:
                    continue
        
        print("Kein funktionierender Audio-Player gefunden (paplay, ogg123, aplay).")
        return False

class SoundInstaller:
    """Installiert Sounds gemäß Freedesktop-Spezifikation."""
    def __init__(self):
        self._ensure_paths()

    def _ensure_paths(self):
        # RECHTE-SCHUTZ: try-except für Ordnererstellung
        try:
            STEREO_PATH.mkdir(parents=True, exist_ok=True)
            self._create_index_theme()
        except (PermissionError, OSError) as e:
            print(f"[-] Fehler: Keine Schreibrechte in {THEME_PATH.parent}: {e}")
            sys.exit(1)

    def _create_index_theme(self):
        index_file = THEME_PATH / "index.theme"
        if not index_file.exists():
            content = f"""[Sound Theme]
Name={SOUND_THEME_NAME}
Comment=Automatisch installierte Sounds via galert CLI
Directories=stereo

[stereo]
OutputProfile=stereo
"""
            try:
                with open(index_file, "w") as f:
                    f.write(content)
            except (PermissionError, OSError) as e:
                print(f"[-] Fehler: Konnte index.theme nicht erstellen: {e}")
                sys.exit(1)

    def install(self, source_path, event_name):
        # DOWNLOAD-SCHUTZ: Vor Installation prüfen
        if not source_path.exists() or source_path.stat().st_size == 0:
            print("[-] Fehler: Quelldatei existiert nicht oder ist leer.")
            return False

        target_file = STEREO_PATH / event_name
        try:
            shutil.copy(source_path, target_file)
            print(f"Sound erfolgreich als '{event_name}' in '{SOUND_THEME_NAME}' installiert.")
            return True
        except (PermissionError, OSError) as e:
            print(f"[-] Fehler beim Kopieren der Datei: {e}")
            return False

