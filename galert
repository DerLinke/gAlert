        rprint(f"          {C_L10}█{C_L11}█[/]     {C_R17}█{C_R18}█{C_R19}█{C_R20}█{C_R21}█[/]")
        rprint(f"     {C_L5}█{C_L6}█[/]                    {C_R26}█{C_R27}█[/]")
        rprint(f"{C_L0}█{C_L1}█[/]                {C_R18}█{C_R19}█{C_R20}█{C_R21}█{C_R22}█[/] [bold white]gAlert v1.0.0[/bold white]")
        rprint(f"     {C_L5}█{C_L6}█[/]                    {C_R26}█{C_R27}█[/]")
        rprint(f"          {C_L10}█{C_L11}█[/]     {C_R17}█{C_R18}█{C_R19}█{C_R20}█{C_R21}█[/]\n")

    def run(self):
        self.show_banner()
        parser = argparse.ArgumentParser(description="gAlert: Freesound CLI Sound Installer")
        parser.add_argument("--search", type=str, help="Suchbegriff für Freesound.org")
        args = parser.parse_args()

        if args.search:
            self.handle_search(args.search)
        else:
            parser.print_help()

    def handle_search(self, query):
        print(f"Suche nach '{query}' auf Freesound.org...")
        results = self.api.search(query)

        if not results:
            print("Keine Ergebnisse gefunden.")
            return

        for i, res in enumerate(results, 1):
            print(f"{i}. [{res['id']}] {res['name']} ({res['license']})")

        choice = input("\nWähle eine Nummer (1-5) oder 'q' zum Beenden: ")
        if choice.lower() == 'q' or not choice.isdigit() or int(choice) > len(results):
            return

        selected = results[int(choice) - 1]
        
        # API-SCHUTZ: Robuster Zugriff auf Previews
        previews = selected.get("previews", {})
        preview_url = previews.get("preview-hq-ogg")
        
        if not preview_url:
            print(f"[-] Fehler: Keine OGG-Vorschau für Sound ID {selected['id']} ('{selected['name']}') verfügbar.")
            return

        self.handle_item_menu(selected, preview_url)

    def handle_item_menu(self, sound_data, preview_url):
        temp_file = Path("/tmp") / f"galert_{sound_data['id']}.ogg"
        
        while True:
            print(f"\nGewählter Sound: {sound_data['name']}")
            print("[P] Preview anhören")
            print("[I] Als Systemsound installieren")
            print("[A] Abbrechen")
            
            cmd = input("Aktion: ").lower()

            if cmd == 'p':
                if not temp_file.exists():
                    print("Lade Vorschau herunter...")
                    if not self.api.download_preview(preview_url, temp_file):
                        continue
                print("Spiele Vorschau ab...")
                self.player.play(temp_file)
            
            elif cmd == 'i':
                if not temp_file.exists():
                    print("Lade Sound herunter...")
                    if not self.api.download_preview(preview_url, temp_file):
                        continue
                
                self.handle_install_menu(temp_file)
                break
            
            elif cmd == 'a':
                break

    def handle_install_menu(self, sound_file):
        print("\nVerfügbare Ereignisse:")
        for k, (filename, description) in EVENT_MAPPING.items():
            print(f"{k} = {filename}")
            print(f"    -> {description}")
        
        ev_choice = input("\nWähle ein Ereignis (1-4): ")
        if ev_choice in EVENT_MAPPING:
            event_name = EVENT_MAPPING[ev_choice][0]
            self.installer.install(sound_file, event_name)
        else:
            print("Ungültige Auswahl.")

